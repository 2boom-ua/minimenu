{
  "manifest_version": 3,
  "name": "Text Mini Menu",
  "version": "1.6",
  "description": "Show mini menu when selecting text",
  "default_locale": "en",
  "author": "(c) 2boom 2026",
  "minimum_chrome_version": "114",

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "search",
    "clipboardRead",
    "clipboardWrite"
  ],

  "icons": {
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "minimenu.js"
      ],
      "run_at": "document_end"
    }
  ]
}