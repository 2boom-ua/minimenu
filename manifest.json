{
  "manifest_version": 3,
  "name": "Text Mini Menu",
  "version": "1.5",
  "description": "Show mini menu when selecting text",
  "default_locale": "en",
  "background": { "service_worker": "background.js" },
  "permissions": [
    "search",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icons/icon-128.png"
  },
   "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["minimenu.js"],
      "run_at": "document_end"
    }
  ]
}
